<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="EMWorkflow">
    <GuiElement profile="uiInGameMenuFrame">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg" />
            <Text profile="fs25_menuHeaderTitle" text="$l10n_em_tab_workflows" />
        </GuiElement>

        <GuiElement profile="emptyPanel" id="mainBox" position="0px -80px">

            <GuiElement profile="emMenuLeftColumn" size="440px 780px">
                <Text profile="EM_SectionTitle" position="20px -10px" text="$l10n_em_list_owned" />

                <SmoothList id="employeeList" profile="emMenuList" position="10px -35px" width="420px" height="700px"
                            selectedWithoutFocus="true">
                    <ListItem profile="emMenuListItem" width="400px">
                        <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/>
                        <Text profile="emMenuListItemTitle" name="title"/>
                        <Text profile="emMenuListItemSubtitle" name="subtitle"/>
                    </ListItem>
                </SmoothList>

                <ThreePartBitmap profile="emMenuListSliderBox" position="-10px -35px" height="700px">
                    <Slider profile="fs25_listSlider" dataElementId="employeeList" />
                </ThreePartBitmap>
            </GuiElement>

            <GuiElement profile="emMenuRightColumn" size="920px 780px" position="450px 0px">

                <BoxLayout profile="EM_RowBoxH" position="10px -10px" width="900px">
                    <Text profile="EM_InfoLabel" text="$l10n_em_field_selector" width="140px"/>
                    <MultiTextOption profile="EM_InfoSelector" id="fieldSelector" onClick="onFieldChanged" size="300px 32px"/>
                </BoxLayout>

                <BoxLayout profile="EM_RowBoxH" position="10px -50px" width="900px">
                    <Text profile="EM_InfoLabel" text="$l10n_em_assigned_vehicle" width="140px"/>
                    <MultiTextOption profile="EM_InfoSelector" id="vehicleSelector" onClick="onVehicleChanged" size="300px 32px"/>
                </BoxLayout>

                <BoxLayout profile="EM_RowBoxH" position="10px -90px" width="900px">
                    <Text profile="EM_InfoLabel" text="$l10n_em_shift_label" width="140px"/>
                    <MultiTextOption profile="EM_InfoSelector" id="shiftStartSelector" onClick="onShiftStartChanged" size="110px 32px"/>
                    <Text profile="EM_InfoLabel" text="$l10n_em_shift_to" width="30px"/>
                    <MultiTextOption profile="EM_InfoSelector" id="shiftEndSelector" onClick="onShiftEndChanged" size="110px 32px"/>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -135px" width="900px"/>

                <!-- Skills summary -->
                <Text profile="EM_SectionTitle" position="10px -148px" text="$l10n_em_employee_skills_title"/>
                <Text profile="EM_SkillXP" id="txtSkillsSummary" position="10px -168px" width="900px"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -195px" width="900px"/>

                <Text profile="EM_SectionTitle" position="10px -208px" text="$l10n_em_workflow_builder"/>

                <Text profile="EM_InfoLabel" position="10px -230px" text="$l10n_em_available_tasks" width="340px" textSize="14px"/>
                <Text profile="EM_InfoLabel" position="470px -230px" text="$l10n_em_workflow_queue" width="340px" textSize="14px"/>

                <SmoothList id="availableTasksList" profile="WE_TaskList" position="10px -250px" width="340px" height="450px">
                    <ListItem profile="EM_ListItem" height="30px" width="330px">
                        <Text profile="fs25_textDefault" name="title" textSize="16px"/>
                    </ListItem>
                </SmoothList>

                <BoxLayout profile="EM_ColBoxV" position="365px -370px" width="60px">
                    <Button profile="buttonActivate" text="&gt;&gt;" onClick="onTaskAdd" size="55px 32px"/>
                    <Button profile="buttonActivate" text="&lt;&lt;" onClick="onTaskRemove" size="55px 32px"/>
                </BoxLayout>

                <SmoothList id="queueList" profile="WE_TaskList" position="470px -250px" width="340px" height="450px">
                    <ListItem profile="EM_ListItem" height="30px" width="330px">
                        <Text profile="fs25_textDefault" name="title" textSize="16px"/>
                    </ListItem>
                </SmoothList>

                <BoxLayout profile="EM_ColBoxV" position="825px -370px" width="55px">
                    <Button profile="buttonActivate" text="^" onClick="onTaskUp" size="42px 32px"/>
                    <Button profile="buttonActivate" text="v" onClick="onTaskDown" size="42px 32px"/>
                </BoxLayout>

                <Text profile="EM_SkillXP" id="txtStatusMessage" position="10px -720px" width="900px"/>

            </GuiElement>
        </GuiElement>

        <Text profile="emMenuEmptyText" id="emptyText" text="$l10n_em_error_no_hired" visible="false" />
    </GuiElement>
</GUI>
