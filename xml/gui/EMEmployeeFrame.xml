<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="EMEmployee">
    <GuiElement profile="uiInGameMenuFrame">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg" />
            <Text profile="fs25_menuHeaderTitle" text="$l10n_em_tab_employees" />
        </GuiElement>

        <GuiElement profile="emptyPanel" id="mainBox" position="0px -80px">

            <GuiElement profile="emMenuLeftColumn" size="320px 780px">
                <MultiTextOption profile="EM_FilterSwitcher" id="listSwitcher" onClick="onSwitchList" size="280px 32px" position="20px -10px"/>

                <SmoothList id="employeeList" profile="emMenuList" position="10px -35px" width="300px" height="700px"
                            selectedWithoutFocus="true">
                    <ListItem profile="EM_ListItem">
                        <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/>
                        <Text profile="emMenuListItemTitle" name="title"/>
                        <Text profile="emMenuListItemSubtitle" name="subtitle"/>
                    </ListItem>
                </SmoothList>

                <ThreePartBitmap profile="emMenuListSliderBox">
                    <Slider profile="fs25_listSlider" dataElementId="employeeList" />
                </ThreePartBitmap>

                <Text profile="EM_InfoLabel" id="txtPoolRefresh" position="20px -720px" visible="false"/>
            </GuiElement>

            <GuiElement profile="emMenuRightColumn" id="detailPanel" size="420px 780px" position="340px 0px">
                <Text profile="EM_InfoLabel" id="txtId" position="10px -10px"/>
                <Text profile="EM_InfoTitle" id="txtName" position="10px -30px"/>

                <BoxLayout profile="EM_ColBoxV" position="10px -70px" width="360px">
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_employee_status_label"/>
                        <Text profile="EM_InfoValue" id="txtStatus"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_label_trait"/>
                        <Text profile="EM_InfoValue" id="txtTrait"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_assigned_field"/>
                        <Text profile="EM_InfoValue" id="txtAssignedField"/>
                    </BoxLayout>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -155px" width="360px"/>

                <Text profile="EM_SectionTitle" position="10px -170px" text="$l10n_em_employee_skills_title"/>

                <BoxLayout profile="EM_ColBoxV" position="10px -190px" width="360px">
                    <BoxLayout profile="EM_RowBoxH" width="360px">
                        <Text profile="EM_SkillLabel" text="$l10n_em_skill_driving"/>
                        <Text profile="EM_SkillStars" id="skillDrivingStars"/>
                        <Text profile="EM_SkillXP" id="skillDrivingXP"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH" width="360px">
                        <Text profile="EM_SkillLabel" text="$l10n_em_skill_harvesting"/>
                        <Text profile="EM_SkillStars" id="skillHarvestingStars"/>
                        <Text profile="EM_SkillXP" id="skillHarvestingXP"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH" width="360px">
                        <Text profile="EM_SkillLabel" text="$l10n_em_skill_technical"/>
                        <Text profile="EM_SkillStars" id="skillTechnicalStars"/>
                        <Text profile="EM_SkillXP" id="skillTechnicalXP"/>
                    </BoxLayout>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -280px" width="360px"/>

                <Text profile="EM_SectionTitle" position="10px -295px" text="$l10n_em_employee_stats_title"/>

                <BoxLayout profile="EM_ColBoxV" position="10px -315px" width="360px">
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_hours_worked"/>
                        <Text profile="EM_InfoValue" id="statHoursWorked"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_km_driven"/>
                        <Text profile="EM_InfoValue" id="statKmDriven"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_current_job"/>
                        <Text profile="EM_InfoValue" id="statCurrentJob"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_fatigue"/>
                        <Text profile="EM_InfoValue" id="statFatigue"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_shift_label"/>
                        <Text profile="EM_InfoValue" id="statShift"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_parking"/>
                        <Text profile="EM_InfoValue" id="statParking"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_pending_wages"/>
                        <Text profile="EM_InfoValue" id="statPendingWages"/>
                    </BoxLayout>
                </BoxLayout>

                <Text profile="EM_InfoLabel" id="statFatigueStatus" position="10px -475px" visible="false"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -490px" width="360px"/>
                <Text profile="EM_SectionTitle" position="10px -505px" text="$l10n_em_performance_title"/>

                <BoxLayout profile="EM_ColBoxV" position="10px -525px" width="360px">
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_total_wages"/>
                        <Text profile="EM_InfoValue" id="statTotalWages"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_tasks_completed"/>
                        <Text profile="EM_InfoValue" id="statTasksCompleted"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_avg_wage"/>
                        <Text profile="EM_InfoValue" id="statAvgWage"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_efficiency"/>
                        <Text profile="EM_InfoValue" id="statEfficiency"/>
                    </BoxLayout>
                </BoxLayout>

                <Text profile="EM_InfoLabel" id="txtUnpaidWarning" position="10px -610px" visible="false"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -620px" width="360px"/>
                <Text profile="EM_SectionTitle" position="10px -635px" text="$l10n_em_workflow_builder"/>
                <Text profile="EM_InfoLabel" id="txtWorkflowSummary" position="10px -655px" width="360px"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="10px -685px" width="360px"/>
                <Text profile="EM_FooterLabel" position="10px -700px" text="$l10n_em_employee_total_wage"/>
                <Text profile="EM_FooterValue" position="10px -700px" id="txtWage" width="360px"/>
                <Text profile="EM_InfoLabel" id="txtWageBreakdown" position="10px -720px" width="360px"/>
            </GuiElement>
        </GuiElement>

        <Text profile="emMenuEmptyText" id="emptyText" text="$l10n_em_employee_empty" visible="false" />
    </GuiElement>
</GUI>
