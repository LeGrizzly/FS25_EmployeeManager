<?xml version="1.0" encoding="UTF-8"?>
<GUI name="ingameMenuEmployeeManager">
    <GuiElement profile="emFrame_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap id="categoryHeaderIcon" profile="emFrame_menuHeaderIcon" />
            </Bitmap>
            <Text id="categoryHeaderText" profile="fs25_menuHeaderTitle" text="Employee Manager" />
        </GuiElement>

        <GuiElement profile="fs25_statisticsHeaderBox">
            <Text profile="fs25_vehiclesHeaderName" text="$l10n_ui_name" />
            <GuiElement position="440px 0px" profile="fs25_vehiclesHeaderTextContainer">
                <Text profile="fs25_vehiclesHeaderText" text="$l10n_em_skill_driving" />
            </GuiElement>
            <GuiElement position="620px 0px" profile="fs25_vehiclesHeaderTextContainer">
                <Text profile="fs25_vehiclesHeaderText" text="$l10n_em_skill_harvesting" />
            </GuiElement>
            <GuiElement position="800px 0px" profile="fs25_vehiclesHeaderTextContainer">
                <Text profile="fs25_vehiclesHeaderText" text="$l10n_em_skill_technical" />
            </GuiElement>
            <GuiElement position="980px 0px" profile="fs25_vehiclesHeaderTextContainer">
                <Text profile="fs25_vehiclesHeaderText" text="$l10n_em_assigned_vehicle" />
            </GuiElement>
            <GuiElement position="1160px 0px" profile="fs25_vehiclesHeaderTextContainer">
                <Text profile="fs25_vehiclesHeaderText" text="$l10n_em_current_job" />
            </GuiElement>
            <GuiElement position="1340px 0px" profile="fs25_vehiclesHeaderTextContainer">
                <Text profile="fs25_vehiclesHeaderText" text="$l10n_ui_missionStatusTitle" />
            </GuiElement>
            <ThreePartBitmap position="0px -2dp" profile="fs25_lineSeparatorBottom" />
        </GuiElement>
        <SmoothList id="list" profile="emFrame_list">
            <ListItem name="rowTemplate" profile="fs25_vehiclesListItem">
                <ThreePartBitmap name="alternating" profile="fs25_vehiclesListItemBg" />
                <Text name="name" profile="fs25_vehiclesListItemName" />
                <Text name="skillDriving" position="440px 0px" profile="fs25_vehiclesListItemInfo" />
                <Text name="skillHarvesting" position="620px 0px" profile="fs25_vehiclesListItemInfo" />
                <Text name="skillTechnical" position="800px 0px" profile="fs25_vehiclesListItemInfo" />
                <Text name="assignedVehicle" position="980px 0px" profile="fs25_vehiclesListItemInfo" />
                <Text name="currentJob" position="1160px 0px" profile="fs25_vehiclesListItemInfo" />
                <Text name="status" position="1340px 0px" profile="fs25_vehiclesListItemInfo" />
            </ListItem>
        </SmoothList>
        <GuiElement id="detailBox" visible="true" profile="emFrame_detailsContainer">
            <Bitmap name="startClipper" position="-2px 140px" profile="fs25_stopClipper" />
            <Bitmap profile="emFrame_detailsImageBg">
                <Bitmap id="itemDetailsImage" profile="emFrame_detailsImage" />
            </Bitmap>
            <Text id="itemDetailsName" profile="emFrame_detailsName" />
        </GuiElement>
    </GuiElement>

    <ThreePartBitmap id="frameSliderBox" profile="fs25_sliderDockedBg">
        <ThreePartBitmap profile="fs25_sliderDockedBox">
            <Slider dataElementId="list" id="frameSlider" profile="fs25_sliderDocked" />
        </ThreePartBitmap>
    </ThreePartBitmap>

    <GuiProfiles>
        <!-- <Profile name="emFrame_menuHeaderIcon" extends="fs25_menuHeaderIcon">
            <imageSliceId value="icon" />
        </Profile> -->
        <Profile name="emFrame_menuContainer" extends="fs25_menuContainer">
            <position value="-76px 80px" />
        </Profile>

        <Profile name="emFrame_detailsContainer" extends="fs25_shopItemsDetailsContainer">
            <height value="150px" />
        </Profile>

        <Profile name="emFrame_detailsImageBg" extends="fs25_vehiclesDetailsImageBg">
            <size value="170px 170px" />
            <position value="0px -35px" />
        </Profile>

        <Profile name="emFrame_detailsImage" extends="fs25_vehiclesDetailsImage">
            <size value="125px 125px" />
        </Profile>

        <Profile name="emFrame_detailsName" extends="fs25_vehiclesDetailsName">
            <absoluteSizeOffset value="520px 0px" />
            <position value="190px -30px" />
            <textSize value="24px" />
        </Profile>

        <Profile name="emFrame_list" extends="fs25_vehiclesList">
            <position value="0px -34px" />
            <absoluteSizeOffset value="0px 175px" />
        </Profile>
    </GuiProfiles>
</GUI>
