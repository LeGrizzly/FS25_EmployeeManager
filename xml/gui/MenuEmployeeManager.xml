<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="menuEmployeeManager">
    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg"/>
            <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText"/>
            <RoundCorner profile="fs25_shopMoneyBoxBg" id="shopMoneyBoxBg"/>
            <BoxLayout profile="fs25_shopMoneyBox" id="shopMoneyBox">
                <Text profile="fs25_shopBalance" text="$l10n_em_current_balance"/>
                <Text profile="fs25_shopMoney" id="currentBalanceText"/>
            </BoxLayout>
        </GuiElement>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px 0px">
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg">
                <Bitmap profile="fs25_menuContainerArrow"/>

                <GuiElement profile="fs25_subCategoryContainer">
                    <MultiTextOption profile="EM_FilterSwitcher" id="pageSwitcher" onClick="onSwitchPage" size="380px 32px" position="20px -40px"/>
                    
                    <GuiElement profile="fs25_subCategoryListContainer">
                        <Bitmap profile="fs25_subCategoryStartClipper" name="startClipper"/>
                        <Bitmap profile="fs25_subCategoryStopClipper" name="endClipper"/>
                        
                        <SmoothList id="leftListTable" profile="EM_List" startClipperElementName="startClipper" endClipperElementName="endClipper">
                            <ListItem profile="EM_ListItem">
                                <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/>
                                <Text profile="EM_ListItemTitle" name="title"/>
                                <Text profile="EM_ListItemInfo" name="subtitle"/>
                            </ListItem>
                        </SmoothList>
                        
                        <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
                            <Slider profile="fs25_listSlider" dataElementId="leftListTable" />
                        </ThreePartBitmap>
                    </GuiElement>
                </GuiElement>
            </ThreePartBitmap>

            <Text id="noSelectedText" profile="EM_HeaderLeft" text="$l10n_em_employee_empty" position="460px -230px" width="500px" />

            <GuiElement id="employeeInfoContainer" width="1087px" position="460px -40px" visible="false">
                <Text profile="EM_InfoLabel" id="employeeId" position="0px -5px"/>
                <Text profile="EM_InfoTitle" id="employeeName" position="0px -30px"/>

                <BoxLayout profile="EM_ColBoxV" position="0px -70px" width="500px">
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_employee_status_label"/>
                        <Text profile="EM_InfoValue" id="employeeStatusValue"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_assigned_field"/>
                        <Text profile="EM_InfoValue" id="txtAssignedField"/>
                    </BoxLayout>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -140px" width="600px"/>

                <Text profile="EM_SectionTitle" position="0px -155px" text="$l10n_em_employee_skills_title"/>

                <BoxLayout profile="EM_ColBoxV" position="0px -175px" width="600px">
                    <BoxLayout profile="EM_RowBoxH" width="600px">
                        <Text profile="EM_SkillLabel" text="$l10n_em_skill_driving"/>
                        <Text profile="EM_SkillStars" id="skillDrivingStars"/>
                        <Text profile="EM_SkillXP" id="skillDrivingXP"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH" width="600px">
                        <Text profile="EM_SkillLabel" text="$l10n_em_skill_harvesting"/>
                        <Text profile="EM_SkillStars" id="skillHarvestingStars"/>
                        <Text profile="EM_SkillXP" id="skillHarvestingXP"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH" width="600px">
                        <Text profile="EM_SkillLabel" text="$l10n_em_skill_technical"/>
                        <Text profile="EM_SkillStars" id="skillTechnicalStars"/>
                        <Text profile="EM_SkillXP" id="skillTechnicalXP"/>
                    </BoxLayout>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -260px" width="600px"/>
                <Text profile="EM_SectionTitle" position="0px -275px" text="$l10n_em_employee_stats_title"/>

                <BoxLayout profile="EM_ColBoxV" position="0px -295px" width="600px">
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_hours_worked"/>
                        <Text profile="EM_InfoValue" id="statHoursWorked"/>
                    </BoxLayout>
                    <BoxLayout profile="EM_RowBoxH">
                        <Text profile="EM_InfoLabel" text="$l10n_em_stat_current_job"/>
                        <Text profile="EM_InfoValue" id="statCurrentJob"/>
                    </BoxLayout>
                </BoxLayout>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -360px" width="600px"/>
                <Text profile="EM_SectionTitle" position="0px -375px" text="$l10n_em_workflow_builder"/>
                <Text profile="EM_InfoLabel" id="txtWorkflowSummary" position="0px -395px" width="600px"/>

                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -430px" width="600px"/>
                <Text profile="EM_FooterLabel" position="0px -445px" text="$l10n_em_employee_total_wage"/>
                <Text profile="EM_FooterValue" position="0px -445px" id="employeeWageValue" width="600px"/>
            </GuiElement>

            <GuiElement id="workflowContainer" width="1087px" position="460px -40px" visible="false">
                <Text profile="EM_InfoTitle" text="Field Workflow" position="0px -10px"/>
                
                <BoxLayout profile="EM_RowBoxH" position="0px -80px">
                    <Text profile="EM_InfoLabel" text="Target Crop:"/>
                    <MultiTextOption profile="EM_FilterSwitcher" id="cropSelector" onClick="onCropChanged" size="300px 32px"/>
                </BoxLayout>

                <SmoothList id="workflowTable" profile="EM_List" position="0px -150px" width="600px" height="400px">
                    <ListItem profile="EM_WorkflowListItem">
                        <Bitmap profile="fs25_subCategoryListItemIcon" name="statusIcon"/>
                        <Text profile="EM_ListItemTitle" name="stepName" position="60px 0px"/>
                        <MultiTextOption profile="fs25_subCategorySelector" name="assigneeSelector" position="280px -10px" size="250px 32px"/>
                    </ListItem>
                </SmoothList>
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
